# Required
OPENAI_API_KEY=your_api_key_here

# Optional — defaults shown
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_IDENTITY=         # set to use a different model for identity resolution (e.g. gpt-4o-mini)
OPENAI_BASE_URL_IDENTITY=      # ignored unless OPENAI_MODEL_IDENTITY is set
OPENAI_API_KEY_IDENTITY=       # ignored unless OPENAI_MODEL_IDENTITY is set
MAX_AGENT_STEPS=25       # fallback for all agents below if not set individually
MAX_IDENTITY_STEPS=10
MAX_PROFILE_STEPS=25
MAX_NEWS_STEPS=25
MAX_CONTENT_CHARS=       # unset = unlimited; set to e.g. 10000 to truncate per-page content
NEWS_WINDOW_DAYS=90
CRAWL4AI_BROWSER_MODE=regular   # regular | stealth | undetected
CRAWL4AI_PAGE_TIMEOUT=15000    # ms — how long to wait for a page to load before giving up
CRAWL4AI_VERBOSE=0             # 1 to print crawl4ai logs to stdout (always written to fetched/<id>.crawl4ai.log)
